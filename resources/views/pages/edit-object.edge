@let(catMap = {
  'Sport & Loisirs': 'sport',
  'Culture & Livres': 'books',
  'Vêtements': 'clothes',
  'Informatique & Tech': 'tech',
  'Maison & Cuisine': 'home',
  'Jouets & Enfants': 'toys',
  'Électroménager': 'appliances',
  'Musique & Art': 'art',
  'Bureau & Fournitures': 'office'
})

{{-- Déterminer si c'est un objet donation ou cherche --}}
@let(isDonation = object.type !== undefined)
@let(isCherche = !isDonation)

<main>
  @include('partials/flash')
  <h1>{{ t('messages.edit_item.title') }}  {{ object.name }}</h1>

  {{-- La route update avec l'ID de l'objet --}}
  @if(isDonation)
    <form id="editForm" action="{{ route('donation_objects.update', { id: object.id }) }}" method="POST" enctype="multipart/form-data">
  @else
    <form id="editForm" action="{{ route('cherche_objects.update', { id: object.id }) }}" method="POST" enctype="multipart/form-data">
  @endif
    {{ csrfField() }}

    {{-- Pour Adonis, on utilise l'ID de route POST mais on simule le PUT ou PATCH --}}
    <input type="hidden" name="_method" value="POST"> {{-- Ou PATCH selon ton controller --}}

    {{-- Section Image --}}
    <div>
      @!component('components/input', {
        name : 'image',
        label : t('messages.edit_item.image_placeholder'),
        type : 'file',
        attributes: { id: 'image' }
      })
      @if(object.imagePath)
      <img id="imageDisplay" src="/uploads/items/{{ object.imagePath }}" alt="Aperçu">
      @else
      <img class="CACHER" id="imageDisplay" src="" alt="Aperçu">
      @endif
    </div>

    <br>

    {{-- Nom --}}
    <div class="field-group">
      <label for="name">{{ t('messages.add_item.name_label') }}</label><br>
