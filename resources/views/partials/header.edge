  @vite([`resources/css/${css}`, 'resources/css/app.css', 'resources/js/app.js'])

  <title>
    {{ title ? `${title} | ${t('messages.site.title')}` : t('messages.site.title') }}
  </title>
</head>

<body>
  @let(isSearchMode = !!isCherchePage)
  @let(toggleLabel = isSearchMode ? t('messages.nav.don') : t('messages.nav.search'))
  @let(toggleRouteName = isSearchMode ? 'donation_objects.index' : 'cherche_objects.index')

  <header>
    {{-- Logo cliquable vers Home via route nommée --}}
    <a href="{{ route('donation_objects.index') }}" class="logo">
      <img src="{{ asset('resources/img/logo.png') }}" alt="{{ t('messages.site.logo_alt') }}">
    </a>

    <div class="bouton">
      <div class="bouton">
        {{-- Bouton admin (visible seulement pour les admins) --}}
        @if(auth.isAuthenticated && auth.user.isadmin)
        <a href="{{ route('admin.dashboard') }}" class="action-button admin-button" title="{{ t('messages.admin.dashboard_title') }}">
          <i class="fa fa-shield-halved" aria-hidden="true"></i> {{ t('messages.nav.admin') }}
        </a>
        @end
        <a href="{{ route(toggleRouteName) }}" class="action-button mode-switch-button">
          {{ toggleLabel }}
        </a>

        {{-- Ajouter un objet --}}
        <a href="{{ route('donation_objects.create') }}" class="action-button add-button">
          {{ t('messages.nav.add') }}
        </a>

        {{-- Compte utilisateur --}}
        <a href="{{ route('account') }}" class="textdeco account-link">
          <img src="{{ asset('resources/img/user.svg') }}" class="imgbutton" alt="{{ t('messages.site.user_alt') }}" />
        </a>


        {{-- Sélecteur de langue Desktop --}}
        <div class="lang-switcher header-lang-switcher">
          <a href="?lang=fr" class="lang-link {{ i18n.locale === 'fr' ? 'active' : '' }}">FR</a>
          <span>|</span>
          <a href="?lang=en" class="lang-link {{ i18n.locale === 'en' ? 'active' : '' }}">EN</a>
        </div>
      </div>
  </header>

  {{-- Barre d'action mobile --}}
  <div class="bottom-action-bar">
    <a href="{{ route('donation_objects.create') }}" class="action-button">
      {{ t('messages.nav.add') }}
    </a>

    <a href="{{ route(toggleRouteName) }}" class="action-button">
      {{ toggleLabel }}
    </a>

    <a href="{{ route('account') }}" class="action-button">
      {{ t('messages.nav.account') }}
    </a>

      @if(auth.isAuthenticated && auth.user.isadmin)
