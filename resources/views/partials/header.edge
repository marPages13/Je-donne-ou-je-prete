<!DOCTYPE html>
<html lang="{{ i18n.locale }}">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="ie=edge">

  {{-- Utilisation de asset() pour l'icône : sécurité max pour les chemins --}}
  <link rel="icon" type="image/x-icon" href="{{ asset('resources/img/logo.png') }}">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  @vite([`resources/css/${css}`, 'resources/css/app.css', 'resources/js/app.js'])

  <title>{{ title || '404' }} | {{ t('messages.test') ? 'Je donne, je prête' : 'Give or Lend' }}</title>
</head>

<body>
  <header>
    {{-- Logo cliquable vers Home via route nommée --}}
    <a href="{{ route('donation_objects.index') }}" class="logo">
      <img src="{{ asset('resources/img/logo.png') }}" alt="Logo">
    </a>

    <div class="bouton">
      {{-- Ajouter un objet --}}
      <a href="{{ route('donation_objects.create') }}" class="action-button">
        {{ t('messages.nav.add') }}
      </a>

      {{-- Compte utilisateur --}}
      <a href="{{ route('account') }}" class="textdeco">
        <img src="{{ asset('resources/img/user.svg') }}" class="imgbutton" alt="User">
      </a>

      {{-- Sélecteur de langue Desktop --}}
      <div class="lang-switcher">
        <a href="?lang=fr" class="lang-link {{ i18n.locale === 'fr' ? 'active' : '' }}">FR</a>
        <span>|</span>
        <a href="?lang=en" class="lang-link {{ i18n.locale === 'en' ? 'active' : '' }}">EN</a>
      </div>
    </div>
  </header>

  {{-- Barre d'action mobile --}}
  <div class="bottom-action-bar">
    <a href="{{ route('donation_objects.create') }}" class="action-button">
      {{ t('messages.nav.add') }}
    </a>

    <a href="{{ route('account') }}" class="action-button">
      {{ t('messages.nav.account') }}
    </a>

    <div class="lang-switcher">
      <a href="?lang=fr" class="lang-link {{ i18n.locale === 'fr' ? 'active' : '' }}">FR</a>
      <span>|</span>
      <a href="?lang=en" class="lang-link {{ i18n.locale === 'en' ? 'active' : '' }}">EN</a>
    </div>
  </div>